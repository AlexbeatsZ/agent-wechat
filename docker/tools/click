#!/bin/bash
# Click at coordinates, optionally activating a specific window first.
# Usage: click [--window <pid> <x> <y> <width> <height> [window-id] --] <x> <y> [button]

set -euo pipefail

if [ "${1:-}" = "--window" ]; then
  if [ "$#" -lt 8 ]; then
    echo "Usage: $0 --window <pid> <x> <y> <width> <height> [window-id] -- ..." >&2
    exit 1
  fi
  WIN_PID="$2"; WIN_X="$3"; WIN_Y="$4"; WIN_W="$5"; WIN_H="$6"
  shift 6
  WIN_ID=""
  if [ "${1:-}" != "--" ]; then
    WIN_ID="$1"
    shift
  fi
  if [ "${1:-}" = "--" ]; then shift; fi
  SCRIPT_DIR="$(dirname "$0")"
  if [ -n "$WIN_ID" ]; then
    "$SCRIPT_DIR/window-activate" "$WIN_PID" "$WIN_X" "$WIN_Y" "$WIN_W" "$WIN_H" "$WIN_ID" >/dev/null || echo "Warning: could not activate window" >&2
  else
    "$SCRIPT_DIR/window-activate" "$WIN_PID" "$WIN_X" "$WIN_Y" "$WIN_W" "$WIN_H" >/dev/null || echo "Warning: could not activate window" >&2
  fi
fi

if [ -z "${1:-}" ] || [ -z "${2:-}" ]; then
  echo "Usage: click <x> <y> [button]" >&2
  exit 1
fi

X="$1"; Y="$2"; BUTTON="${3:-1}"
xdotool mousemove "$X" "$Y" click "$BUTTON"
echo "clicked at ($X, $Y)"
