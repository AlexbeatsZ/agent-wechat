#!/bin/bash
# Type text using clipboard paste (Unicode-safe).
# Usage: input [--window <pid> <x> <y> <width> <height> [window-id] --] "<text>"

set -euo pipefail

if [ "${1:-}" = "--window" ]; then
  if [ "$#" -lt 8 ]; then
    echo "Usage: $0 --window <pid> <x> <y> <width> <height> [window-id] -- ..." >&2
    exit 1
  fi
  WIN_PID="$2"; WIN_X="$3"; WIN_Y="$4"; WIN_W="$5"; WIN_H="$6"
  shift 6
  WIN_ID=""
  if [ "${1:-}" != "--" ]; then
    WIN_ID="$1"
    shift
  fi
  if [ "${1:-}" = "--" ]; then shift; fi
  SCRIPT_DIR="$(dirname "$0")"
  if [ -n "$WIN_ID" ]; then
    "$SCRIPT_DIR/window-activate" "$WIN_PID" "$WIN_X" "$WIN_Y" "$WIN_W" "$WIN_H" "$WIN_ID" >/dev/null || echo "Warning: could not activate window" >&2
  else
    "$SCRIPT_DIR/window-activate" "$WIN_PID" "$WIN_X" "$WIN_Y" "$WIN_W" "$WIN_H" >/dev/null || echo "Warning: could not activate window" >&2
  fi
fi

if [ -z "${1:-}" ]; then
  echo "Usage: input "<text>"" >&2
  exit 1
fi

TEXT="$1"
echo -n "$TEXT" | xclip -selection clipboard >/dev/null 2>&1 &
sleep 0.1
xdotool key ctrl+v
sleep 0.05
echo "typed: $TEXT"
